# Nóos backend environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value marked CHANGE_ME.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# Generate SECRET_KEY with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./noos.db

# ── Security ─────────────────────────────────────────────────────────────────
# CHANGE_ME: replace with output of `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME

# ── Token expiry ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" in prod; enables HSTS and strict secret validation.
ENVIRONMENT=development

# ── Reports ──────────────────────────────────────────────────────────────────
REPORTS_DIR=../reports

# ── Initial admin account ────────────────────────────────────────────────────
# CHANGE_ME: must meet password policy (≥12 chars, upper, lower, digit, symbol)
# Leave blank to skip auto-creation of the admin user.
ADMIN_PASSWORD=CHANGE_ME
